{
  "manifest_version": 3,
  "name": "Save Image As PNG/JPG",
  "version": "1.0.0",
  "description": "Right-click any web image (including WebP) to instantly convert and download it as PNG or JPG.",
  "permissions": [
    "contextMenus",
    "downloads",
    "scripting",
    "activeTab",
    "notifications"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}